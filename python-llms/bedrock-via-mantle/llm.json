  "params": [
    {
      "name": "region",
      "label": "Region",
      "description": "AWS region name for the bedrock-mantle endpoint",
      "type": "STRING",
      "defaultValue": "us-west-2",
      "mandatory": true
    },
    {
      "name": "apiKey",
      "label": "Bedrock or OpenAI API key",
