{
  "meta": {
    "label": "Amazon Bedrock via Converse API",
    "description": "Text completion models powered by Amazon Bedrock. Note that prices vary per region. When applicable, this is the us-east-1 cost.",
    "icon": "fas fa-cloud"
  },
  "params": [
    {
      "name": "s3Connection",
      "label": "S3 connection",
      "description": "The credentials of that connection will be used to connect to Bedrock",
      "type": "CONNECTION",
      "mandatory": false
    },
    {
      "name": "region",
      "label": "Region",
      "description": "AWS region name",
      "type": "STRING",
      "defaultValue": "us-east-1",
      "mandatory": false
    },
    {
      "name": "inferenceProfile",
      "label": "Inference profile",
      "description": "Optional Bedrock cross-region inference profile (e.g. us, eu, apac). See the AWS documentation for which models and regions are supported.",
      "type": "STRING",
      "mandatory": false
    },
    {
      "name": "maxParallelism",
      "label": "Max parallelism",
      "type": "INT",
      "defaultValue": 8,
      "mandatory": false
    },
    {
      "name": "useGuardrail",
      "label": "Bedrock Guardrail",
      "description": "Use a Bedrock Guardrail created in this region. It will be applied to all enabled models in this connection.",
      "type": "BOOLEAN",
      "defaultValue": false,
      "mandatory": false
    },
    {
      "name": "guardrailIdentifier",
      "label": "Guardrail Identifier",
      "type": "STRING",
      "mandatory": false,
      "visibilityCondition": "model.useGuardrail"
    },
    {
      "name": "guardrailVersion",
      "label": "Guardrail Version",
      "type": "STRING",
      "defaultValue": "DRAFT",
      "mandatory": false,
      "visibilityCondition": "model.useGuardrail"
    },
